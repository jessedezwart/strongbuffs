#!/bin/bash
# Pre-commit hook: runs JS/TS lint and format checks, then checkstyle on staged Java files

echo "Running website lint..."
npm run lint:website
RESULT=$?

if [ $RESULT -ne 0 ]; then
	echo ""
	echo "Website lint failed. Please fix issues before committing."
	exit 1
fi

echo "Running formatting check..."
npm run format:check
RESULT=$?

if [ $RESULT -ne 0 ]; then
	echo ""
	echo "Formatting check failed. Run 'npm run format' and commit again."
	exit 1
fi

# Get list of staged .java files
STAGED_JAVA_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.java$')

if [ -z "$STAGED_JAVA_FILES" ]; then
	exit 0
fi

echo "Running checkstyle on staged Java files..."

# Run checkstyle via Gradle
./gradlew checkstyleMain checkstyleTest --quiet 2>&1
RESULT=$?

if [ $RESULT -ne 0 ]; then
	echo ""
	echo "Checkstyle violations found. Please fix them before committing."
	echo "Run './gradlew checkstyleMain checkstyleTest' to see details."
	exit 1
fi

echo "Checkstyle passed."
exit 0
